---
import { Image } from 'astro:assets';
import logoDesaNgenep from '../assets/images/logo_desa_ngenep.png';
---
<footer class="bg-navy text-white mt-auto border-t border-navy-light/30">
  <!-- Top Footer Container -->
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16 grid grid-cols-1 md:grid-cols-3 gap-10">
    
    <!-- Left Column: Description -->
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <div class="p-1 rounded bg-white/10">
          <Image src={logoDesaNgenep} alt="Logo Resmi Desa Ngenep" class="w-8 h-8 object-contain" />
        </div>
        <span class="text-xl font-bold tracking-wider font-serif">DESA NGENEP</span>
      </div>
      <p class="text-sm text-slate-300 leading-relaxed font-sans max-w-sm">
        Pemerintah Desa Ngenep berkomitmen memberikan pelayanan terbaik yang transparan dan akuntabel kepada seluruh warga masyarakat.
      </p>
    </div>

    <!-- Middle Column: Quick Links -->
    <div class="space-y-4">
      <h3 class="text-xs uppercase tracking-widest text-slate-300 font-bold border-b border-navy-light/40 pb-2">Menu Utama</h3>
      <div class="grid grid-cols-2 gap-x-4 gap-y-2.5 text-sm font-sans">
        <a href="/" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Beranda
        </a>
        <a href="/profil" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Profil
        </a>
        <a href="/berita" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Berita
        </a>
        <a href="/transparansi" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Transparansi
        </a>
        <a href="/hukum" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Hukum
        </a>
        <a href="/wisata" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Wisata
        </a>
        <a href="/galeri" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Galeri
        </a>
        <a href="/kontak" class="text-slate-300 hover:text-terracotta flex items-center gap-1.5 transition-colors duration-200">
          <span class="text-terracotta text-xs">›</span> Kontak
        </a>
      </div>
    </div>

    <!-- Right Column: Contact Details -->
    <div class="space-y-4">
      <h3 class="text-xs uppercase tracking-widest text-slate-300 font-bold border-b border-navy-light/40 pb-2">Kontak</h3>
      <div class="space-y-3.5 text-sm text-slate-300 font-sans">
        <div class="flex items-start gap-3">
          <!-- Location Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="leading-relaxed">Jl. Singo Joyo, Karangploso Viul, Ngenep, Kec. Karang Ploso, Kabupaten Malang, Jawa Timur 65152</span>
        </div>
        <div class="flex items-center gap-3">
          <!-- Phone Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>085142505492</span>
        </div>
        <div class="flex items-center gap-3">
          <!-- Email Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:ngenepdesa@gmail.com" class="hover:text-terracotta transition-colors duration-200">ngenepdesa@gmail.com</a>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Copyright -->
  <div class="bg-navy-dark border-t border-navy-light/10 py-5">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-slate-400 font-sans">
      <span>© 2026 Pemerintah Desa Ngenep. Hak Cipta Dilindungi.</span>
      <div class="flex items-center gap-2">
        <span class="inline-block w-2.5 h-2.5 bg-terracotta"></span>
        <span>Dikelola oleh Pemerintah Desa Ngenep</span>
      </div>
    </div>
  </div>

  <!-- Floating Help/Bantuan Button -->
  <a 
    href="/kontak"
    class="fixed bottom-6 right-6 bg-terracotta hover:bg-terracotta-dark text-white font-bold px-4 py-2.5 rounded shadow-lg flex items-center gap-2 transition-all duration-300 hover:scale-105 z-40 border border-terracotta-light/20 text-xs sm:text-sm uppercase tracking-wider"
  >
    <!-- Question Mark Help Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    Bantuan
  </a>
</footer>
