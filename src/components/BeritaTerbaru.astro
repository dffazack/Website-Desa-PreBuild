---
import { Image } from 'astro:assets';
import { newsItems } from '../data/news';
const featuredNews = newsItems[0];
---
<section class="py-16 bg-cream border-t border-slate-200/40">
  <div class="max-w-7xl mx-auto px-4">
    
    <!-- Top Header: Title & Navigation -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-8">
      <div>
        <h3 class="text-3xl font-black font-serif text-slate-800 tracking-tight">Berita Terbaru</h3>
        <p class="text-slate-500 text-sm mt-1 font-sans font-medium">Kabar terkini dari Desa Ngenep</p>
        <span class="w-16 h-1 bg-terracotta inline-block mt-3" aria-hidden="true"></span>
      </div>
      
      <a 
        href="/berita" 
        class="border-2 border-navy hover:bg-navy hover:text-white text-navy font-bold px-6 py-2.5 rounded text-sm transition-all duration-300 flex items-center gap-2 font-sans"
      >
        BACA SEMUA BERITA
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>

    <!-- Main Content Layout (Grid) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left Column: Featured News -->
      <div class="lg:col-span-8 bg-white border border-slate-200/60 rounded overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 scroll-reveal active">
        <div class="grid grid-cols-1 md:grid-cols-12">
          
          <!-- Image Section (Astro Assets Optimized) -->
          <div class="md:col-span-5 h-64 md:h-auto min-h-[250px] relative overflow-hidden">
            <Image 
              src={featuredNews.image} 
              alt={featuredNews.title} 
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
          
          <!-- Content Section -->
          <div class="md:col-span-7 p-6 sm:p-8 flex flex-col justify-between">
            <div class="space-y-4">
              <!-- Meta: Category & Date -->
              <div class="flex items-center gap-3 text-xs font-semibold tracking-wider font-sans">
                <span class="bg-navy text-white px-2.5 py-0.5 rounded uppercase">{featuredNews.category}</span>
                <span class="text-slate-400">📅 {featuredNews.date}</span>
              </div>
              
              <!-- Title -->
              <h4 class="text-xl sm:text-2xl font-bold font-serif text-slate-800 leading-tight">
                {featuredNews.title}
              </h4>
              
              <!-- Excerpt -->
              <p class="text-sm text-slate-500 leading-relaxed font-sans">
                {featuredNews.excerpt}
              </p>
            </div>
            
            <!-- Read More Link -->
            <div class="pt-6 font-sans">
              <a 
                href={`/berita/${featuredNews.slug}`} 
                class="text-terracotta hover:text-terracotta-dark font-bold text-sm tracking-wide inline-flex items-center gap-1.5 transition-colors duration-200"
              >
                Baca Selengkapnya
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>

          </div>

        </div>
      </div>

      <!-- Right Column: Sidebar (Service Hours & Contacts) -->
      <div class="lg:col-span-4 space-y-8">
        
        <!-- Service Hours Widget -->
        <div class="bg-white border border-slate-200/60 rounded shadow-sm overflow-hidden scroll-reveal active">
          <!-- Widget Header -->
          <div class="bg-navy text-white px-5 py-4 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h4 class="font-bold text-sm tracking-widest uppercase font-sans">Jam Pelayanan</h4>
          </div>
          
          <!-- Widget Body (Table) -->
          <div class="p-5 bg-cream-light/40">
            <div class="divide-y divide-slate-200/60 text-sm font-sans">
              <div class="flex justify-between py-2.5">
                <span class="text-slate-600 font-medium">Senin - Jumat</span>
                <span class="text-slate-800 font-bold">08.00 WIB - Selesai</span>
              </div>
              <div class="flex justify-between py-2.5">
                <span class="text-slate-600 font-medium">Sabtu - Minggu & Libur</span>
                <span class="text-terracotta font-bold uppercase tracking-wider">TUTUP</span>
              </div>
            </div>
            
            <p class="text-[11px] leading-relaxed text-slate-400 mt-4 border-t border-slate-200/40 pt-3">
              * Jam pelayanan dapat berubah pada hari-hari besar atau tertentu. Konfirmasi layanan sebelum datang melalui telepon kantor desa.
            </p>
          </div>
        </div>

        <!-- Contact Widget -->
        <div class="bg-white border border-slate-200/60 rounded shadow-sm overflow-hidden scroll-reveal active">
          <!-- Widget Header -->
          <div class="bg-terracotta text-white px-5 py-4 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <h4 class="font-bold text-sm tracking-widest uppercase font-sans">Kontak Desa</h4>
          </div>
          
          <!-- Widget Body -->
          <div class="p-5 bg-cream-light/40 space-y-4 font-sans text-sm">
            <div class="flex items-start gap-4">
              <div class="bg-slate-100 p-2 rounded text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">WhatsApp</span>
                <span class="block font-bold text-slate-700 mt-0.5">085142505492</span>
              </div>
            </div>

            <div class="flex items-start gap-4 border-t border-slate-200/40 pt-4">
              <div class="bg-slate-100 p-2 rounded text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">Email Resmi</span>
                <a href="mailto:ngenepdesa@gmail.com" class="block font-bold text-slate-700 hover:text-terracotta mt-0.5 transition-colors duration-200">
                  ngenepdesa@gmail.com
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>

  </div>
</section>
