---
import { Image } from 'astro:assets';
import petaWisata from '../assets/images/peta_wisata.webp';
---
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
  
  <!-- Left Column: Geographical Table -->
  <div class="lg:col-span-7 space-y-6 scroll-reveal active">
    <div>
      <h3 class="text-2xl font-black font-serif text-slate-800 tracking-tight">Informasi Wilayah</h3>
      <p class="text-slate-500 text-sm mt-1 font-sans font-medium">Data geografi dan demografis Desa Ngenep</p>
      <span class="w-16 h-1 bg-terracotta inline-block mt-3"></span>
    </div>

    <!-- Info Table -->
    <div class="bg-white border border-slate-200/60 rounded shadow-sm overflow-hidden font-sans">
      <div class="divide-y divide-slate-100 text-sm">
        
        <!-- Row 1 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Nama Desa</span>
          <span class="col-span-7 font-bold text-slate-800">Ngenep</span>
        </div>

        <!-- Row 2 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Kecamatan</span>
          <span class="col-span-7 font-bold text-slate-800">Karangploso</span>
        </div>

        <!-- Row 3 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Kabupaten / Kota</span>
          <span class="col-span-7 font-bold text-slate-800">Malang</span>
        </div>

        <!-- Row 4 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Provinsi</span>
          <span class="col-span-7 font-bold text-slate-800">Jawa Timur</span>
        </div>

        <!-- Row 5 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Kode Pos</span>
          <span class="col-span-7 font-bold text-slate-800">65152</span>
        </div>

        <!-- Row 6 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Jumlah Penduduk</span>
          <span class="col-span-7 font-bold text-slate-800">13.829 Jiwa</span>
        </div>

        <!-- Row 7 -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Jumlah Kepala Keluarga</span>
          <span class="col-span-7 font-bold text-slate-800">6.214 KK</span>
        </div>

        <!-- Row 8 (Batas Utara) -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Batas Utara</span>
          <span class="col-span-7 font-bold text-slate-800">Desa Langlang, Kec. Singosari</span>
        </div>

        <!-- Row 9 (Batas Selatan) -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Batas Selatan</span>
          <span class="col-span-7 font-bold text-slate-800">Desa Kepuharjo dan Desa Ngijo, Kec. Karangploso</span>
        </div>

        <!-- Row 10 (Batas Timur) -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Batas Timur</span>
          <span class="col-span-7 font-bold text-slate-800">Desa Tunjung Tirto, Kec. Singosari</span>
        </div>

        <!-- Row 11 (Batas Barat) -->
        <div class="grid grid-cols-12 py-3 px-4 sm:px-6 hover:bg-slate-50/50 transition-colors duration-150">
          <span class="col-span-5 text-slate-500 font-medium">Batas Barat</span>
          <span class="col-span-7 font-bold text-slate-800">Desa Ngijo dan Desa Bocek, Kec. Karangploso</span>
        </div>

      </div>
    </div>
  </div>

  <!-- Right Column: Location Map & Access info -->
  <div class="lg:col-span-5 space-y-8 scroll-reveal active">
    
    <!-- Peta Lokasi Widget -->
    <div class="space-y-4">
      <div>
        <h3 class="text-2xl font-black font-serif text-slate-800 tracking-tight">Peta Lokasi</h3>
        <p class="text-slate-500 text-sm mt-1 font-sans font-medium">Lokasi Kantor Desa Ngenep</p>
        <span class="w-16 h-1 bg-terracotta inline-block mt-3"></span>
      </div>

      <!-- Real Map iframe or premium mock container -->
      <div class="bg-white border border-slate-200/60 rounded p-2.5 shadow-sm overflow-hidden h-72 relative">
        <iframe 
          title="Peta Kantor Desa Ngenep"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3952.128795908053!2d112.5937989!3d-7.8816047!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e78807908b89693%3A0xad5bd864817a3a93!2sNgenep%2C%20Karang%20Ploso%2C%20Malang%20Regency%2C%20East%20Java!5e0!3m2!1sen!2sid!4v1700000000000!5m2!1sid!2sid" 
          class="w-full h-full border-0 rounded"
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>

    <!-- Akses & Transportasi Card -->
    <div class="border-2 border-navy border-opacity-95 rounded overflow-hidden shadow-sm bg-white font-sans">
      <!-- Card Header -->
      <div class="bg-navy text-white px-5 py-3.5 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h4 class="font-bold text-xs uppercase tracking-widest">Akses & Transportasi</h4>
      </div>
      <!-- Card Body -->
      <div class="p-5 space-y-3.5 text-sm text-slate-700 leading-relaxed">
        <div class="flex items-start gap-2.5">
          <span class="text-terracotta text-base line-none flex-shrink-0">■</span>
          <span>Aksesibilitas Wilayah: <strong class="text-slate-800">Sangat strategis di bagian utara Kabupaten Malang</strong></span>
        </div>
        <div class="flex items-start gap-2.5">
          <span class="text-terracotta text-base line-none flex-shrink-0">■</span>
          <span>Aksesibilitas Kota: <strong class="text-slate-800">Memiliki akses mudah menuju pusat Karangploso, Kota Malang, dan Kota Batu</strong></span>
        </div>
        <div class="flex items-start gap-2.5 border-t border-slate-100 pt-3.5 mt-3.5">
          <span class="text-terracotta text-base line-none flex-shrink-0">■</span>
          <span>Akses Kendaraan: <strong class="text-slate-800">Dapat dijangkau dengan mobil, motor, ojek, serta taksi online</strong></span>
        </div>
      </div>
    </div>

  </div>

  <!-- Peta Wisata Utama Section (Full Width) -->
  <div class="lg:col-span-12 mt-10 scroll-reveal active font-sans">
    <div class="space-y-4 mb-6">
      <h3 class="text-2xl font-black font-serif text-slate-800 tracking-tight">Peta Wisata Utama Desa Ngenep</h3>
      <p class="text-slate-500 text-sm mt-1 font-sans font-medium">Panduan rute dan lokasi destinasi wisata potensial di wilayah Desa Ngenep</p>
      <span class="w-16 h-1 bg-terracotta inline-block mt-1"></span>
    </div>
    
    <div class="bg-white border border-slate-200/60 rounded-xl p-4 sm:p-6 shadow-sm overflow-hidden space-y-4">
      <div class="relative rounded-lg overflow-hidden border border-slate-100 group max-h-[600px] flex items-center justify-center bg-slate-50">
        <Image 
          src={petaWisata} 
          alt="Peta Wisata Utama Desa Ngenep" 
          class="max-w-full max-h-[580px] w-auto h-auto object-contain transition-transform duration-500 group-hover:scale-[1.01]"
        />
      </div>
      <div class="flex flex-wrap items-center justify-between gap-4 pt-2 border-t border-slate-100 text-sm">
        <p class="text-slate-500 font-medium">
          * Klik tombol di sebelah kanan untuk melihat peta dalam resolusi penuh.
        </p>
        <a 
          href={petaWisata.src} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy hover:bg-navy/90 text-white text-xs font-bold uppercase tracking-wider rounded transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Lihat Resolusi Penuh
        </a>
      </div>
    </div>
  </div>

</div>
