---
import type { MenuItem } from '../data/types';

interface Props {
  activePath: string;
}

const { activePath } = Astro.props;

const isPathActive = (path: string): boolean => {
  if (path === '/' && activePath === '/') return true;
  if (path !== '/' && activePath.startsWith(path)) return true;
  return false;
};

const menuItems: MenuItem[] = [
  { name: 'BERANDA', href: '/' },
  { name: 'PROFIL', href: '/profil' },
  { name: 'BERITA', href: '/berita' },
  { name: 'TRANSPARANSI', href: '/transparansi' },
  { name: 'HUKUM', href: '/hukum' },
  { name: 'WISATA', href: '/wisata' },
  { name: 'GALERI', href: '/galeri' },
  { name: 'KONTAK', href: '/kontak' },
];
---

<header class="shadow-md relative z-40">
  <!-- Top Logo Banner -->
  <div class="bg-navy text-white py-4 border-b border-navy-light/20">
    <div class="max-w-7xl mx-auto px-4 flex items-center gap-4">
      <!-- Shield Logo Box -->
      <a href="/" class="flex items-center gap-4 group" aria-label="Beranda Website Resmi Desa Ngenep">
        <div class="border-2 border-terracotta/80 p-2.5 rounded shadow-inner bg-navy-dark transition-colors duration-300 group-hover:border-terracotta">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white transition-transform duration-300 group-hover:scale-105" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div>
          <span class="block text-lg md:text-xl font-bold tracking-wider font-serif">WEBSITE RESMI DESA NGENEP</span>
          <span class="block text-xs text-slate-300 tracking-wide mt-0.5 font-sans">Kecamatan Karangploso · Kabupaten Malang · Provinsi Jawa Timur</span>
        </div>
      </a>
    </div>
  </div>

  <!-- Main Navbar -->
  <nav class="bg-white border-b border-slate-200" aria-label="Navigasi Utama">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center h-14 md:h-16">
      
      <!-- Desktop Navigation Menu -->
      <div class="hidden lg:flex items-center space-x-1 h-full">
        {menuItems.map(item => {
          const active = isPathActive(item.href);
          return (
            <a 
              href={item.href}
              class={`flex items-center h-full px-4 text-sm font-semibold tracking-wide border-b-4 transition-all duration-200 ${
                active 
                  ? 'border-terracotta text-terracotta' 
                  : 'border-transparent text-slate-600 hover:text-navy hover:border-navy-light/40'
              }`}
              aria-current={active ? 'page' : undefined}
            >
              {item.name}
            </a>
          );
        })}
      </div>

      <!-- Hamburger Menu Button (Mobile) -->
      <button 
        id="menu-toggle"
        type="button" 
        class="lg:hidden p-2 text-slate-600 hover:text-navy focus:outline-none focus:ring-2 focus:ring-terracotta rounded"
        aria-label="Buka menu navigasi"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Right Search Box -->
      <div class="flex items-center gap-2">
        <form action="/berita" method="GET" class="relative flex items-center" role="search">
          <label for="search-input" class="sr-only">Cari berita...</label>
          <input 
            type="text" 
            id="search-input"
            name="q" 
            placeholder="Cari..." 
            class="bg-slate-50 border border-slate-200 px-3 py-1.5 pr-10 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-44 sm:w-56 rounded-l"
          />
          <button 
            type="submit" 
            class="bg-navy hover:bg-navy-dark text-white p-2 border border-navy focus:outline-none rounded-r flex items-center justify-center transition-colors duration-200"
            aria-label="Cari"
          >
            <svg xmlns=".\src\assets\images\search-interface-symbol.pngj" class="h-4.5 w-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </form>
      </div>

    </div>

    <!-- Mobile Navigation Dropdown Menu -->
    <div 
      id="mobile-menu" 
      class="hidden lg:hidden bg-cream-light border-t border-slate-200 px-4 py-2 space-y-1 shadow-inner animate-fade-in"
      aria-hidden="true"
    >
      {menuItems.map(item => {
        const active = isPathActive(item.href);
        return (
          <a 
            href={item.href}
            class={`block px-3 py-2.5 rounded text-sm font-semibold transition-all duration-200 ${
              active 
                ? 'bg-terracotta text-white' 
                : 'text-slate-700 hover:bg-slate-100 hover:text-navy'
            }`}
            aria-current={active ? 'page' : undefined}
          >
            {item.name}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const toggleBtn = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDivElement | null;

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
      mobileMenu.setAttribute('aria-hidden', String(isExpanded));
    });
  }
</script>
