---
import { 
  apbdesSummary, 
  pendapatanKomposisi, 
  alokasiBelanja, 
  rincianAnggaran 
} from '../data/documents';
---
<div class="space-y-12">
  <!-- Title Section -->
  <div class="scroll-reveal active flex flex-col md:flex-row md:items-center md:justify-between border-b border-slate-200 pb-6 gap-4">
    <div>
      <h3 class="text-2xl md:text-3xl font-black font-serif text-slate-800 tracking-tight">APB DESA DESA NGENEP 2025</h3>
      <p class="text-slate-500 text-sm mt-1 font-sans">Laporan Transparansi Anggaran Pendapatan dan Belanja Desa Ngenep Tahun 2025</p>
      <span class="w-16 h-1 bg-terracotta inline-block mt-3" aria-hidden="true"></span>
    </div>
    <div class="text-xs text-slate-500 bg-slate-100 p-3 rounded-lg border border-slate-200/80 font-sans space-y-1">
      <div><span class="font-bold text-slate-700">Menteri Desa PDT:</span> H. Yandri Susanto, S.Pt., M.Pd</div>
      <div><span class="font-bold text-slate-700">Kepala Desa Ngenep:</span> SUWARDI</div>
    </div>
  </div>

  <!-- Summary Cards Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 scroll-reveal active">
    {apbdesSummary.map(summary => (
      <div class={`bg-white border border-slate-200 border-l-4 ${summary.color} rounded-lg p-6 shadow-sm`}>
        <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider font-sans">{summary.title}</span>
        <h4 class="text-2xl md:text-3xl font-black font-serif text-slate-800 tracking-tight mt-1.5">{summary.value}</h4>
        <span class="block text-xs text-slate-500 mt-2 font-medium font-sans leading-relaxed">{summary.subtitle}</span>
      </div>
    ))}
  </div>

  <!-- Charts Layout Container -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 scroll-reveal active">
    
    <!-- Chart 1: Komposisi Pendapatan -->
    <div class="bg-white border border-slate-200/80 rounded-lg p-6 sm:p-8 shadow-sm space-y-6">
      <div>
        <h4 class="font-bold text-lg text-slate-800 font-serif tracking-wide">Komposisi Pendapatan</h4>
        <p class="text-xs text-slate-400 mt-0.5 font-sans">Total Pendapatan: <span class="font-semibold text-slate-700">Rp 2.967.161.000,00</span></p>
      </div>

      <!-- Graph representation lists -->
      <div class="space-y-4">
        {pendapatanKomposisi.map(item => (
          <div class="space-y-1.5 font-sans">
            <div class="flex justify-between text-xs sm:text-sm font-bold text-slate-700">
              <span>{item.label}</span>
              <span>{item.percentage}% ({item.valStr})</span>
            </div>
            <div class="w-full bg-slate-100 h-3 rounded-full overflow-hidden" role="progressbar" aria-valuenow={item.percentage} aria-valuemin={0} aria-valuemax={100}>
              <div class={`h-full rounded-full ${item.color}`} style={`width: ${item.percentage}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Chart 2: Alokasi Belanja -->
    <div class="bg-white border border-slate-200/80 rounded-lg p-6 sm:p-8 shadow-sm space-y-6">
      <div>
        <h4 class="font-bold text-lg text-slate-800 font-serif tracking-wide">Alokasi Belanja</h4>
        <p class="text-xs text-slate-400 mt-0.5 font-sans">Total Belanja: <span class="font-semibold text-slate-700">Rp 2.846.953.232,00</span></p>
      </div>

      <!-- Graph lists -->
      <div class="space-y-4">
        {alokasiBelanja.map(item => (
          <div class="space-y-1.5 font-sans">
            <div class="flex justify-between text-xs sm:text-sm font-bold text-slate-700">
              <span class="flex items-center gap-2">
                <span class="inline-block w-2.5 h-2.5 rounded-full bg-terracotta" aria-hidden="true"></span>
                {item.label} ({item.code})
              </span>
              <span>{item.valStr} ({item.pctValue}%)</span>
            </div>
            <div class="w-full bg-slate-100 h-3 rounded-full overflow-hidden">
              <div class="bg-terracotta h-full rounded-full" style={`width: ${item.pctValue}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- Detailed Table -->
  <div class="space-y-6 scroll-reveal active">
    <div class="bg-navy text-white px-6 py-4 flex items-center justify-between rounded-t-lg border-b border-navy-light/20">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="font-bold text-sm tracking-widest uppercase font-sans">Rincian Belanja APBDes Tahun Anggaran 2025</h3>
      </div>
      <span class="text-xs bg-navy-light/40 px-3 py-1 rounded text-slate-200 font-sans hidden sm:inline-block">5 Bidang Utama</span>
    </div>

    <!-- Table Container -->
    <div class="bg-white border border-slate-200/80 rounded-b-lg shadow-sm overflow-x-auto font-sans">
      <table class="w-full text-left border-collapse text-slate-700 text-xs sm:text-sm min-w-[700px]">
        <thead>
          <tr class="bg-slate-100 border-b border-slate-200 text-slate-600 font-bold uppercase tracking-wider text-[11px]">
            <th class="py-3.5 px-6 w-28">No / Bidang</th>
            <th class="py-3.5 px-6">Uraian / Sub Bidang</th>
            <th class="py-3.5 px-6 w-52 text-right">Pagu / Nominal</th>
            <th class="py-3.5 px-6 w-40 text-center">Proporsi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200/70">
          {rincianAnggaran.map(row => (
            <>
              <!-- Main Bidang Row -->
              <tr class="bg-slate-50/90 font-bold text-slate-900 border-t border-slate-300">
                <td class="py-3.5 px-6 text-terracotta font-extrabold">{row.bidang}</td>
                <td class="py-3.5 px-6 font-serif text-base">{row.uraian}</td>
                <td class="py-3.5 px-6 text-right font-extrabold text-navy">{row.pagu}</td>
                <td class="py-3.5 px-6 text-center">
                  <span class="inline-block bg-terracotta/10 text-terracotta font-extrabold px-2.5 py-1 rounded-full text-xs">
                    {row.persentase}
                  </span>
                </td>
              </tr>
              <!-- Sub Bidang Rows -->
              {row.subBidang.map((sub, index) => (
                <tr class="hover:bg-amber-50/30 transition-colors duration-150 font-medium">
                  <td class="py-2.5 px-6 text-slate-400 text-xs pl-8 font-mono">{index + 1}.</td>
                  <td class="py-2.5 px-6 leading-normal text-slate-700 pl-8">{sub.nama}</td>
                  <td class="py-2.5 px-6 text-right font-semibold text-slate-800 font-mono">{sub.nominal}</td>
                  <td class="py-2.5 px-6 text-center text-slate-400 text-xs">-</td>
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>
