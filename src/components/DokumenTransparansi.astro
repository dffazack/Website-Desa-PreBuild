---
import { dokumenList } from '../data/documents';
---
<div class="space-y-6">
  <!-- Title Section -->
  <div class="scroll-reveal active">
    <h3 class="text-2xl font-black font-serif text-slate-800 tracking-tight">Dokumen Transparansi</h3>
    <p class="text-slate-500 text-sm mt-1 font-sans font-medium">Dokumen resmi yang dapat diunduh masyarakat</p>
    <span class="w-16 h-1 bg-terracotta inline-block mt-3" aria-hidden="true"></span>
  </div>

  <!-- Downloads List -->
  <div class="space-y-4 scroll-reveal active font-sans">
    {dokumenList.map(doc => (
      <div class="bg-white border border-slate-200/60 rounded p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-sm hover:border-slate-300 transition-colors duration-200">
        
        <!-- Left details -->
        <div class="flex items-center gap-4">
          <!-- Document Icon container (rust bg) -->
          <div class="bg-terracotta/10 p-3 rounded text-terracotta flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          
          <div>
            <h4 class="font-bold text-slate-800 text-sm sm:text-base leading-snug tracking-wide">{doc.title}</h4>
            <p class="text-[11px] font-bold text-slate-400 mt-1 uppercase tracking-wider">{doc.info}</p>
          </div>
        </div>

        <!-- Download Button -->
        <a 
          href={doc.link} 
          class="border border-terracotta text-terracotta hover:bg-terracotta hover:text-white font-bold px-5 py-2.5 rounded text-xs uppercase tracking-wider flex items-center justify-center gap-2 transition-all duration-200 hover:shadow-md w-full sm:w-auto"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Unduh
        </a>

      </div>
    ))}
  </div>
</div>
