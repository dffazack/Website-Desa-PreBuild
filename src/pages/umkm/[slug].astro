---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import IklanLokal from '../../components/IklanLokal.astro';
import { iklanList } from '../../data/ads';
import type { IklanItem } from '../../data/types';

// Astro Dynamic Routing config
export async function getStaticPaths() {
  return iklanList.map(item => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

interface Props {
  item: IklanItem;
}

const { item } = Astro.props;

// Format phone number to international wa.me format
const formatWaNumber = (phone: string): string => {
  return phone.replace(/[^0-9]/g, '').replace(/^0/, '62');
};

const waLink = `https://wa.me/${formatWaNumber(item.phone)}?text=Halo,%20saya%20tertarik%20dengan%20produk%20"${encodeURIComponent(item.name)}"%20yang%20ditampilkan%20di%20Website%20Desa%20Ngenep.`;
---

<Layout title={item.name} description={item.description}>
  
  <!-- Breadcrumbs Bar -->
  <section class="bg-cream pt-8 pb-4 font-sans">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="flex text-xs font-bold uppercase tracking-wider text-slate-400" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-terracotta">Beranda</a>
          </li>
          <li>
            <div class="flex items-center">
              <span class="mx-1.5 md:mx-2 text-slate-300">/</span>
              <span class="text-slate-400 select-none">UMKM</span>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <span class="mx-1.5 md:mx-2 text-slate-300">/</span>
              <span class="text-slate-500 truncate max-w-[200px] md:max-w-xs">{item.name}</span>
            </div>
          </li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- Product Detail Section -->
  <section class="bg-cream pb-16 font-sans">
    <div class="max-w-7xl mx-auto px-4">
      <div class="bg-white border border-slate-200/60 rounded-lg p-6 sm:p-10 shadow-sm">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
          
          <!-- LEFT COLUMN: Product Images -->
          <div class="space-y-4">
            
            <!-- Main Product Image Window -->
            <div class="border border-slate-200 rounded overflow-hidden bg-slate-50 aspect-square flex items-center justify-center relative">
              <Image 
                id="main-product-img"
                src={item.images[0]} 
                alt={item.name} 
                class="w-full h-full object-cover transition-all duration-300"
              />
            </div>


          </div>

          <!-- RIGHT COLUMN: Product Details -->
          <div class="space-y-6">
            
            <div class="space-y-2">
              <!-- Title -->
              <h1 class="text-3xl sm:text-4xl font-black font-serif text-slate-800 leading-tight">
                {item.name}
              </h1>
              
              <!-- Ratings, Reviews & Category Tag -->
              <div class="flex flex-wrap items-center gap-3 text-xs sm:text-sm text-slate-400 font-medium">
                <!-- Stars -->
                <div class="flex text-amber-400 text-sm" aria-label={`Rating ${item.rating} dari 5 bintang`}>
                  {"★".repeat(Math.floor(item.rating))}
                  {item.rating % 1 !== 0 && "½"}
                </div>
                
                <span>|</span>
                <span>Penilaian ({item.reviewsCount})</span>
                <span>|</span>
                
                <!-- Category Tag -->
                <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-600 px-3 py-1 rounded text-xs font-bold font-sans uppercase">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  {item.category}
                </span>
              </div>
            </div>

            <!-- Price Tag (Green & Large) -->
            <div class="py-2 border-y border-slate-100 flex items-center">
              <span class="text-3xl sm:text-4xl font-black text-emerald-700 font-sans tracking-tight">
                {item.price}
              </span>
            </div>

            <!-- Product Description -->
            <div class="space-y-2">
              <span class="block text-xs uppercase tracking-widest text-slate-400 font-bold">Deskripsi Produk</span>
              <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
                {item.description}
              </p>
            </div>

            <!-- CTA: Contact Seller Button (WhatsApp) -->
            <div class="pt-4">
              <a 
                href={waLink}
                target="_blank" 
                rel="noopener noreferrer" 
                class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold px-8 py-4 rounded shadow-lg hover:shadow-emerald-600/20 flex items-center justify-center gap-3 transition-all duration-300 hover:-translate-y-0.5 tracking-wider text-sm uppercase w-full sm:w-auto"
              >
                <!-- WhatsApp SVG icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current text-white" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.968C16.688 2.008 14.218.985 12.01.985c-5.441 0-9.87 4.372-9.874 9.802-.001 1.73.468 3.42 1.358 4.908l-.994 3.629 3.733-.979zm11.758-5.326c-.328-.164-1.942-.958-2.242-1.069-.301-.11-.519-.164-.738.164-.219.328-.847 1.069-1.039 1.288-.192.219-.383.246-.71.082-.328-.164-1.385-.51-2.637-1.628-.974-.87-1.632-1.947-1.823-2.275-.192-.328-.021-.506.143-.669.148-.147.328-.383.492-.574.164-.192.219-.328.328-.547.11-.219.055-.41-.027-.574-.082-.164-.738-1.777-1.011-2.433-.266-.641-.532-.553-.738-.564-.19-.01-.41-.01-.628-.01-.219 0-.574.082-.875.41-.301.328-1.148 1.12-1.148 2.73s1.175 3.167 1.339 3.385c.164.219 2.311 3.528 5.597 4.945.781.337 1.39.539 1.864.69.784.249 1.497.214 2.061.129.629-.094 1.942-.793 2.216-1.559.274-.767.274-1.422.192-1.559-.082-.137-.301-.219-.628-.383z"/>
                </svg>
                Hubungi Penjual
              </a>
            </div>

            <!-- Social Media Share bar -->
            <div class="flex items-center gap-3 pt-6 border-t border-slate-100 text-xs sm:text-sm text-slate-400 font-bold select-none">
              <span>Bagikan:</span>
              <div class="flex gap-2">
                <!-- Facebook -->
                <a 
                  href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border border-slate-200 hover:border-slate-400 rounded p-2 text-slate-500 hover:text-slate-800 transition-colors duration-150 flex items-center justify-center bg-white"
                  aria-label="Bagikan ke Facebook"
                >
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
                  </svg>
                </a>
                
                <!-- WhatsApp -->
                <a 
                  href={`https://api.whatsapp.com/send?text=${encodeURIComponent(item.name + ' - ' + Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border border-slate-200 hover:border-slate-400 rounded p-2 text-slate-500 hover:text-slate-800 transition-colors duration-150 flex items-center justify-center bg-white"
                  aria-label="Bagikan ke WhatsApp"
                >
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12.01 2.01c-5.52 0-10 4.48-10 10 0 1.77.46 3.43 1.27 4.9L2 22l5.24-1.37c1.42.77 3.03 1.21 4.77 1.21 5.52 0 10-4.48 10-10 0-5.52-4.48-10-10-10zm0 18.23c-1.57 0-3.1-.42-4.43-1.22l-.32-.19-3.29.86.88-3.2-.21-.34c-.87-1.39-1.33-3-1.33-4.66 0-4.82 3.92-8.74 8.74-8.74s8.74 3.92 8.74 8.74-3.92 8.74-8.74 8.74z"/>
                  </svg>
                </a>

                <!-- X / Twitter -->
                <a 
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(item.name)}&url=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border border-slate-200 hover:border-slate-400 rounded p-2 text-slate-500 hover:text-slate-800 transition-colors duration-150 flex items-center justify-center bg-white"
                  aria-label="Bagikan ke X"
                >
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>

                <!-- Copy Link Button -->
                <button 
                  id="share-copy-btn"
                  type="button"
                  class="border border-slate-200 hover:border-slate-400 rounded p-2 text-slate-500 hover:text-slate-800 transition-colors duration-150 flex items-center justify-center bg-white cursor-pointer relative"
                  aria-label="Salin Tautan"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                  </svg>
                  <span id="copy-tooltip" class="hidden absolute -top-8 bg-slate-800 text-white text-[10px] px-2 py-1 rounded shadow select-none">Tersalin!</span>
                </button>
              </div>
            </div>

          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- Local Ad Banner -->
  <IklanLokal />

</Layout>

<script>
  // Elements Selection with Strict Types
  const copyBtn = document.getElementById('share-copy-btn') as HTMLButtonElement | null;
  const copyTooltip = document.getElementById('copy-tooltip') as HTMLSpanElement | null;

  // Copy Link Button Logic
  if (copyBtn && copyTooltip) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        // Show tooltip
        copyTooltip.classList.remove('hidden');
        
        // Hide tooltip after 1.5 seconds
        setTimeout(() => {
          copyTooltip.classList.add('hidden');
        }, 1500);
      }).catch(err => {
        console.error('Gagal menyalin tautan: ', err);
      });
    });
  }
</script>

