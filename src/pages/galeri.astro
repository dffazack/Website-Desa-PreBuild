---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import IklanLokal from '../components/IklanLokal.astro';
import { galeriItems } from '../data/gallery';
---

<Layout title="Galeri" description="Dokumentasi foto dan video kegiatan masyarakat dan program pembangunan Pemerintah Desa Sukasari, Kecamatan Sumberejo.">
  
  <section class="bg-cream pt-10 pb-4">
    <div class="max-w-7xl mx-auto px-4">
      
      <!-- Page Title -->
      <div class="flex items-center gap-3 border-l-4 border-terracotta pl-4 mb-8">
        <h2 class="text-3xl md:text-4xl font-black font-serif text-slate-800 tracking-tight">Galeri Desa</h2>
      </div>

      <!-- Introduction Banner card (to match visual designs) -->
      <div class="bg-white border border-slate-200/60 rounded p-8 text-center shadow-sm space-y-4 max-w-4xl mx-auto mb-12 scroll-reveal active font-sans">
        <!-- Icon Container -->
        <div class="bg-cream-dark p-4 rounded-full w-16 h-16 mx-auto flex items-center justify-center text-slate-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        
        <h3 class="text-xl font-bold text-slate-800 font-serif">Galeri Desa</h3>
        <p class="text-slate-500 text-sm max-w-lg mx-auto leading-relaxed">
          Dokumentasi foto dan video kegiatan pemerintah dan masyarakat Desa Sukasari.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-10 font-sans">
        {galeriItems.map(item => (
          <div class="bg-white border border-slate-200/60 rounded overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 group scroll-reveal active hover:-translate-y-0.5">
            <!-- Image Area (Astro Assets Optimized) -->
            <div class="h-56 relative overflow-hidden bg-slate-100">
              <Image 
                src={item.image} 
                alt={item.title} 
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-navy/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>
            </div>
            
            <!-- Description Details -->
            <div class="p-5 space-y-2">
              <span class="text-[10px] font-bold text-terracotta uppercase tracking-wider">
                {item.kategori}
              </span>
              <h4 class="font-bold text-sm text-slate-800 leading-snug tracking-wide group-hover:text-terracotta transition-colors duration-200">
                {item.title}
              </h4>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Local Ad Banner -->
  <IklanLokal />

</Layout>
