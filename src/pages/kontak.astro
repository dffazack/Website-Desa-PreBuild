---
import Layout from '../layouts/Layout.astro';
import IklanLokal from '../components/IklanLokal.astro';
---

<Layout title="Kontak & Pengaduan" description="Hubungi Kantor Pemerintah Desa Ngenep atau kirimkan saran, aspirasi, dan laporan pengaduan Anda melalui formulir online resmi kami.">
  
  <section class="bg-cream pt-10 pb-4">
    <div class="max-w-7xl mx-auto px-4">
      
      <!-- Page Title -->
      <div class="flex items-center gap-3 border-l-4 border-terracotta pl-4 mb-8">
        <h2 class="text-3xl md:text-4xl font-black font-serif text-slate-800 tracking-tight">Kontak & Pengaduan</h2>
      </div>

      <!-- Introduction Banner card (to match visual designs) -->
      <div class="bg-white border border-slate-200/60 rounded p-8 text-center shadow-sm space-y-4 max-w-4xl mx-auto mb-12 scroll-reveal active font-sans">
        <!-- Icon Container -->
        <div class="bg-cream-dark p-4 rounded-full w-16 h-16 mx-auto flex items-center justify-center text-slate-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </div>
        
        <h3 class="text-xl font-bold text-slate-800 font-serif">Kontak & Pengaduan</h3>
        <p class="text-slate-500 text-sm max-w-lg mx-auto leading-relaxed">
          Sampaikan pertanyaan, masukan, dan pengaduan Anda kepada pemerintah Desa Ngenep.
        </p>
      </div>

      <!-- Main Layout: 2 Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 max-w-6xl mx-auto mb-10 font-sans items-start">
        
        <!-- Left Column: Contact details -->
        <div class="lg:col-span-5 space-y-6 scroll-reveal active">
          <div class="bg-white border border-slate-200/60 rounded p-6 sm:p-8 shadow-sm space-y-6">
            <h4 class="font-bold text-base text-navy font-serif tracking-wide border-b border-slate-100 pb-3">
              Informasi Kontak Desa
            </h4>
            
            <div class="space-y-5 text-sm text-slate-600">
              <div class="flex items-start gap-4">
                <div class="bg-slate-100 p-2.5 rounded text-terracotta flex-shrink-0 mt-0.5">
                  <!-- Location Icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">Kantor Desa</span>
                  <p class="mt-0.5 text-slate-700 leading-relaxed font-medium">Jl. Singo Joyo, Karangploso Viul, Ngenep, Kec. Karang Ploso, Kabupaten Malang, Jawa Timur 65152</p>
                </div>
              </div>

              <div class="flex items-start gap-4 border-t border-slate-100 pt-4">
                <div class="bg-slate-100 p-2.5 rounded text-terracotta flex-shrink-0 mt-0.5">
                  <!-- Phone Icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">WhatsApp Chat & Hubungi</span>
                  <p class="mt-0.5 text-slate-700 font-bold">085142505492</p>
                </div>
              </div>

              <div class="flex items-start gap-4 border-t border-slate-100 pt-4">
                <div class="bg-slate-100 p-2.5 rounded text-terracotta flex-shrink-0 mt-0.5">
                  <!-- Mail Icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">Email Resmi</span>
                  <a href="mailto:ngenepdesa@gmail.com" class="block mt-0.5 text-slate-700 hover:text-terracotta font-bold transition-colors duration-200">ngenepdesa@gmail.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4 border-t border-slate-100 pt-4">
                <div class="bg-slate-100 p-2.5 rounded text-terracotta flex-shrink-0 mt-0.5">
                  <span class="font-bold text-slate-500">📱</span>
                </div>
                <div>
                  <span class="block text-xs text-slate-400 font-bold uppercase tracking-wider">Media Sosial</span>
                  <p class="mt-0.5 text-slate-700 font-medium">Instagram: <a href="https://instagram.com/desangenep_official" class="hover:text-terracotta font-bold" target="_blank">@desangenep_official</a></p>
                  <p class="mt-0.5 text-slate-700 font-medium">Facebook: <span class="font-bold">Pemdes Ngenep</span></p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Complaint / Feedback form -->
        <div class="lg:col-span-7 scroll-reveal active">
          <form 
            id="form-pengaduan" 
            class="bg-white border border-slate-200/60 rounded p-6 sm:p-8 shadow-sm space-y-5"
          >
            <h4 class="font-bold text-base text-navy font-serif tracking-wide border-b border-slate-100 pb-3">
              Formulir Aspirasi & Pengaduan Warga
            </h4>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Nama -->
              <div class="space-y-1.5">
                <label for="nama" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">Nama Lengkap</label>
                <input 
                  type="text" 
                  id="nama" 
                  required 
                  class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
                />
              </div>
              <!-- NIK -->
              <div class="space-y-1.5">
                <label for="nik" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">NIK (No. KTP)</label>
                <input 
                  type="text" 
                  id="nik" 
                  required 
                  class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Contact -->
              <div class="space-y-1.5">
                <label for="kontak-detail" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">No. HP / WhatsApp</label>
                <input 
                  type="text" 
                  id="kontak-detail" 
                  required 
                  class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
                />
              </div>
              <!-- Type -->
              <div class="space-y-1.5">
                <label for="jenis-laporan" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">Jenis Laporan</label>
                <select 
                  id="jenis-laporan" 
                  class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
                >
                  <option value="Aspirasi">Saran / Aspirasi</option>
                  <option value="Pengaduan">Laporan Pengaduan</option>
                  <option value="Pertanyaan">Pertanyaan Layanan</option>
                  <option value="Lainnya">Lainnya</option>
                </select>
              </div>
            </div>

            <!-- Subject -->
            <div class="space-y-1.5">
              <label for="subjek" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">Subjek Pesan</label>
              <input 
                type="text" 
                id="subjek" 
                required 
                class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
              />
            </div>

            <!-- Message content -->
            <div class="space-y-1.5">
              <label for="pesan" class="block text-xs font-bold text-slate-500 uppercase tracking-wide">Isi Pesan Laporan</label>
              <textarea 
                id="pesan" 
                rows="4" 
                required 
                class="bg-slate-50 border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-terracotta focus:border-terracotta w-full rounded"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-3">
              <button 
                type="submit" 
                class="bg-terracotta hover:bg-terracotta-dark text-white font-bold px-6 py-3 rounded text-xs uppercase tracking-wider flex items-center justify-center gap-2 transition-all duration-300 shadow hover:shadow-md hover:-translate-y-0.5 w-full sm:w-auto"
              >
                Kirim Laporan
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </div>
          </form>
        </div>

      </div>

    </div>
  </section>

  <!-- Local Ad Banner -->
  <IklanLokal />

</Layout>

<script>
  // Simple form submit feedback
  const form = document.getElementById('form-pengaduan');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Terima kasih. Laporan pengaduan/aspirasi Anda telah berhasil dikirim dan akan segera diproses oleh sekretariat Desa Ngenep.');
      (form as HTMLFormElement).reset();
    });
  }
</script>
